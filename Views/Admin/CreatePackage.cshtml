@{
    ViewData["Title"] = @ViewData["Title"];
}

<div class="page-header">
    <div>
        <div class="page-title">@ViewData["Title"]</div>
        <div class="page-subtitle">Create a new package and map categories with quantities.</div>
    </div>
    <div class="page-header-actions">
        <a class="btn btn-light" href="/Admin/Packages">← Back to Packages</a>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/admin/packages.css" asp-append-version="true">
}

<div class="card package-form-card">
    <div class="form-grid">
        <div class="form-group">
            <label>Package Name <span class="field-required">*</span></label>
            <input id="packageName" name="PackageName" class="form-control" />
            <div class="field-error hidden" id="packageNameError"></div>
        </div>
        <div class="form-group form-span-2">
            <label>Description</label>
            <textarea id="packageDescription" name="PackageDescription" class="form-control" rows="3"></textarea>
        </div>
        <div class="form-group">
            <label>Price <span class="field-required">*</span></label>
            <input id="packagePrice" name="Price" type="number" step="0.01" class="form-control" />
            <div class="field-error hidden" id="packagePriceError"></div>
        </div>
        <div class="form-group">
            <label>Minimum Pax <span class="field-required">*</span></label>
            <input id="minPersons" name="MinPersons" type="number" class="form-control" />
            <div class="field-error hidden" id="minPersonsError"></div>
        </div>
        <div class="form-group">
            <label>Maximum Pax</label>
            <input id="maxPersons" name="MaxPersons" type="number" class="form-control" />
        </div>
    </div>

    <div class="section-header">Package Categories</div>
    <div class="category-list">
        <div class="category-grid-header">
            <div class="category-header-labels">
                <div>Category</div>
                <div>Quantity</div>
            </div>
        </div>
        <div id="categoryRows" class="category-rows"></div>
        <div class="category-footer">
            <button class="btn btn-outline btn-sm add-category-btn" id="addCategoryRow">+ Add Category</button>
        </div>
    </div>

    <div class="form-actions">
        <button class="btn btn-secondary btn-sm" id="clearPackage" type="button">Clear</button>
        <button class="btn btn-orange btn-sm" id="savePackage" type="button">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/packages.js" asp-append-version="true"></script>
}
