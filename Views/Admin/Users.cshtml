@{
    ViewData["Title"] = "Users Management";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">
    <link rel="stylesheet" href="~/css/admin/users.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Users Management</div>
        <div class="page-subtitle">Create, edit and manage system users</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="usersSearch" class="tbl-search" data-table="usersList" placeholder="Search users...">
        </div>
        <button class="btn btn-orange" onclick="openUsersModal()">+ Add User</button>
    </div>
</div>

<div class="pageloaderfull hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading users...</div>
</div>

<div id="usersListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Users</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage users. Assign admin role and control access.</div>
    <div class="pageloaderpanel hidden">
        <div class="spinner"></div>
        <div class="loader-text">Loading users...</div>
    </div>
    <div class="table-wrap">
        <table class="tbl" id="usersList" data-page-size="10">
            <thead>
                <tr><th class="sortable">#</th><th class="sortable">Code</th><th class="sortable">Name</th><th class="sortable">Email</th><th class="sortable">Contact</th><th class="sortable">Admin</th><th class="sortable">Status</th><th class="no-sort">Actions</th></tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<!-- Users Modal -->
<div class="modal-overlay hidden" id="usersModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="users-title">Create / Edit User</span>
            <button class="modal-close" type="button" onclick="closeUsersModal()">✕</button>
        </div>
        <div class="form-row col3">
            <div class="form-group">
                <label>Code <span class="field-required">*</span></label>
                <input type="text" id="userCode" class="form-control" placeholder="User code" />
                <div class="field-error hidden" id="userCodeError"></div>
            </div>
            <div class="form-group">
                <label>Name <span class="field-required">*</span></label>
                <input type="text" id="userName" class="form-control" placeholder="User name" />
                <div class="field-error hidden" id="userNameError"></div>
            </div>
            <div class="form-group">
                <label>Email <span class="field-required">*</span></label>
                <input type="email" id="userEmail" class="form-control" placeholder="Email address" />
                <div class="field-error hidden" id="userEmailError"></div>
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Contact No</label>
                <input type="text" id="userContact" class="form-control" placeholder="Contact number" />
            </div>

            <div class="form-group">
                <label class="checkbox-label" style="margin-top: 34px;">
                    <input type="checkbox" id="userIsAdmin" />
                    <span>Is Admin</span>
                </label>
            </div>
            <div class="form-group">
                <label>Roles</label>
                <select id="userRoles" class="form-control" multiple data-placeholder="Select roles"></select>
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Date Of Birth</label>
                <input type="date" id="userDob" class="form-control" />
            </div>
            <div class="form-group">
                <label>Age</label>
                <input type="text" id="userAge" class="form-control" placeholder="Age" disabled />
            </div>
            <div class="form-group">
                <label>Postal Code</label>
                <input type="text" id="userPostalCode" class="form-control" placeholder="Postal code" />
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Country</label>
                <select id="userCountry" class="form-control">
                    <option value="">Select Country</option>
                    <option value="1">Singapore</option>
                    <option value="2">India</option>
                    <option value="3">Malaysia</option>
                </select>
            </div>
            <div class="form-group">
                <label>State</label>
                <select id="userState" class="form-control">
                    <option value="">Select State</option>
                    <option value="1">Central</option>
                    <option value="2">North</option>
                    <option value="3">South</option>
                    <option value="4">East</option>
                    <option value="5">West</option>
                </select>
            </div>
            <div class="form-group">
                <label>City</label>
                <select id="userCity" class="form-control">
                    <option value="">Select City</option>
                    <option value="1">Singapore</option>
                    <option value="2">Chennai</option>
                    <option value="3">Mumbai</option>
                    <option value="4">Kuala Lumpur</option>
                </select>
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Address 1</label>
                <input type="text" id="userAddress1" class="form-control" placeholder="Address line 1" />
            </div>
            <div class="form-group">
                <label>Address 2</label>
                <input type="text" id="userAddress2" class="form-control" placeholder="Address line 2" />
            </div>
            <div class="form-group">
                <label>Image Upload</label>
                <input type="file" id="userImageFile" class="form-control" accept="image/*" />
                <input type="hidden" id="userImage" />
            </div>
        </div>

        <div class="form-group">
            <img id="userImagePreview" class="hidden" alt="User image preview" style="max-height: 80px; border-radius: 8px; border: 1px solid var(--gray-200);" />
        </div>

        <div class="form-group">
            <label>Remarks</label>
            <input type="text" id="userRemarks" class="form-control" placeholder="Remarks" />
        </div>
        <input type="hidden" id="userId" />
        <input type="hidden" id="userIsActive" value="true" />
        <div class="actions">
            <button type="button" class="btn btn-light" onclick="clearUsersForm(true)">Clear</button>
            <button type="button" id="saveUserBtn" class="btn btn-primary" onclick="saveUser()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/admin/users.js" asp-append-version="true"></script>
}
