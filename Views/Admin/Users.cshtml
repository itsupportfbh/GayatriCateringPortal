@{
    ViewData["Title"] = "Users Management";
}

@section Styles {
    <link rel="stylesheet" href="~/lib/select2/dist/css/select2.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/admin/users.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Users Management</div>
        <div class="page-subtitle">Create, edit and manage system users</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="usersSearch" class="form-control" placeholder="Search users...">
        </div>
        <button class="btn btn-orange btn-add" id="btnAddUser" data-permission="create" onclick="openUsersModal()">+ Add User</button>
    </div>
</div>

<div class="pageloaderfull hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading users...</div>
</div>

<div id="usersListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Users</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage users. Assign admin role and control access.</div>
    <div class="pageloaderpanel hidden">
        <div class="spinner"></div>
        <div class="loader-text">Loading users...</div>
    </div>
    <div id="usersCardsWrap" class="users-cards-wrap">
        <div id="usersCards" class="users-cards-grid"></div>
        <div id="usersCardsEmpty" class="muted users-empty hidden">No users found.</div>
    </div>
</div>

<!-- Users Modal -->
<div class="modal-overlay hidden" id="usersModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="users-title">Create / Edit User</span>
            <button class="modal-close" type="button" onclick="closeUsersModal()">✕</button>
        </div>
        <div class="form-row col4">
            <div class="form-group">
                <label>Code <span class="field-required">*</span></label>
                <input type="text" id="userCode" class="form-control" placeholder="e.g. USR001" />
                <div class="field-error hidden" id="userCodeError"></div>
            </div>
            <div class="form-group">
                <label>Name <span class="field-required">*</span></label>
                <input type="text" id="userName" class="form-control" placeholder="Enter user name" />
                <div class="field-error hidden" id="userNameError"></div>
            </div>
            <div class="form-group">
                <label>Email <span class="field-required">*</span></label>
                <input type="email" id="userEmail" class="form-control" placeholder="name@example.com" />
                <div class="field-error hidden" id="userEmailError"></div>
            </div>

            <div class="form-group">
                <label>Contact No</label>
                <input type="text" id="userContact" class="form-control" placeholder="Enter contact number" />
            </div>
        </div>

        <div class="form-row col4">
            <div class="form-group">
                <label>Roles <span class="field-required">*</span></label>
                <select id="userRoles" class="form-control" multiple data-placeholder="Select roles"></select>
                <div class="field-error hidden" id="userRolesError"></div>
            </div>

            <div class="form-group">
                <label class="checkbox-label" style="margin-top: 34px;">
                    <input type="checkbox" id="userIsAdmin" />
                    <span>Is Admin</span>
                </label>
            </div>

            <div class="form-group">
                <label>Date Of Birth</label>
                <input type="date" id="userDob" class="form-control" />
            </div>

            <div class="form-group">
                <label>Age</label>
                <input type="text" id="userAge" class="form-control" placeholder="Auto-calculated" disabled />
            </div>
        </div>

        <div class="form-row col4">
            <div class="form-group">
                <label>Gender</label>
                <select id="userGender" class="form-control">
                    <option value="">Select Gender</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                    <option value="3">Other</option>
                </select>
            </div>

            <div class="form-group">
                <label>Country</label>
                <select id="userCountry" class="form-control">
                    <option value="0">Select country</option>
                </select>
            </div>

            <div class="form-group">
                <label>State</label>
                <select id="userState" class="form-control">
                    <option value="0">Select state</option>
                </select>
            </div>

            <div class="form-group">
                <label>City</label>
                <select id="userCity" class="form-control">
                    <option value="0">Select city</option>
                </select>
            </div>
        </div>

        <div class="form-row col4">
            <div class="form-group">
                <label>Address 1</label>
                <input type="text" id="userAddress1" class="form-control" placeholder="Enter address line 1" />
            </div>
            <div class="form-group">
                <label>Address 2</label>
                <input type="text" id="userAddress2" class="form-control" placeholder="Enter address line 2 (optional)" />
            </div>
            <div class="form-group">
                <label>Postal Code</label>
                <input type="text" id="userPostalCode" class="form-control" placeholder="Enter postal code" />
            </div>

            <div class="form-group">
                <label>Image Upload</label>
                <input type="file" id="userImageFile" class="form-control" accept="image/*" />
                <input type="hidden" id="userImage" />
                <div class="user-image-preview-row">
                    <img id="userImagePreview" class="hidden" alt="User image preview" style="max-height: 80px; border-radius: 8px; border: 1px solid var(--gray-200);" />
                    <div class="user-image-actions">
                        <button type="button" id="btnViewUserImage" class="btn btn-outline hidden" onclick="viewCurrentUserImage()">View Image</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Remarks</label>
                <textarea id="userRemarks" class="form-control" rows="3" placeholder="Enter remarks (optional)"></textarea>
            </div>
        </div>
        <input type="hidden" id="userId" />
        <input type="hidden" id="userIsActive" value="true" />
        <div class="actions">
            <button type="button" class="btn btn-light" onclick="clearUsersForm(true)">Clear</button>
            <button type="button" id="saveUserBtn" class="btn btn-primary" onclick="saveUser()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/lib/select2/dist/js/select2.min.js" asp-append-version="true"></script>
    <script src="~/js/admin/users.js" asp-append-version="true"></script>
}
