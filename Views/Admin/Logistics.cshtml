@{
    ViewData["Title"] = "Logistics";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/logistics.css" asp-append-version="true">
    }

    <div class="page-header">
        <div>
            <div class="page-title">Logistics</div>
            <div class="page-subtitle">Dispatch and delivery tracking for all active orders</div>
        </div>
    </div>

    <div class="d-flex gap-2 mb-3">
        <button type="button" id="btnPending" class="delivery-tab active">
            🚚 Pending Delivery
        </button>

        <button type="button" id="btnDelivered" class="delivery-tab">
            ✅ Delivered
        </button>
    </div>

    <div id="commsListPanel" class="card">
        <div class="panel-header">
            <div class="panel-title">Dispatch Board</div>
        </div>
        <div class="muted" style="margin-bottom:16px">Track delivery assignments and active order dispatch progress.</div>
        @*  <div class="table-wrap" id="logisticsTable">
            <p class="muted">Loading...</p>
        </div> *@
