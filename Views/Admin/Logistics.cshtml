            <table class="tbl" id="LogisticsList" data-page-size="10">
                <thead>
                    <tr>
                        <th class="sortable">#</th>
                        <th class="sortable">Order Date</th>
                        <th class="sortable">Order Number</th>
                        <th class="sortable">Location</th>
                        <th class="sortable">DriverName </th>
                        <th class="sortable">Status</th>
                        <th class="sortable">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- rows rendered by ~/js/admin/comms.js -->
