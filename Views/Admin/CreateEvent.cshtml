@{ ViewData["Title"] = ViewData["Title"]; }

@section Styles {
    <link rel="stylesheet" href="~/css/admin/eventmaster.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">@ViewData["Title"]</div>
        <div class="page-subtitle">Create an event and map the packages available for it.</div>
    </div>
    <a class="btn btn-light" href="/Admin/EventMaster">&larr; Back to Events</a>
</div>

<div class="card event-form-card">
    <div class="panel-header"><div class="panel-title">Event Details</div></div>
    <div class="form-grid">
        <div class="form-group">
            <label>Event Name <span class="field-required">*</span></label>
            <input id="eventName" class="form-control" placeholder="Enter event name">
            <div class="field-error hidden" id="eventNameError"></div>
        </div>
        <div class="form-group">
            <label>Minimum Pax <span class="field-required">*</span></label>
            <input id="minPax" type="number" min="1" class="form-control" placeholder="Enter minimum pax">
            <div class="field-error hidden" id="minPaxError"></div>
        </div>
        <div class="form-group">
            <label>Advance Booking Days <span class="field-required">*</span></label>
            <input id="advanceBookingDays" type="number" min="0" class="form-control" placeholder="Enter advance booking days">
            <div class="field-error hidden" id="advanceBookingDaysError"></div>
        </div>
        <div class="form-group">
            <label>Service Charge</label>
            <input id="serviceCharge" type="number" min="0" step="0.01" class="form-control" placeholder="Enter service charge">
            <div class="field-error hidden" id="serviceChargeError"></div>
        </div>
    </div>

    <div class="section-header">Event Packages</div>
    <div class="package-list">
        <div id="eventPackageRows" class="package-rows"></div>
        <div class="package-footer"><button type="button" class="btn btn-outline btn-sm" id="addPackageRow">+ Add Package</button></div>
    </div>

    <div class="form-actions">
        <button class="btn btn-light btn-sm" id="clearEvent" type="button">Clear</button>
        <button class="btn btn-primary btn-sm" id="saveEvent" type="button">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/eventmaster.js" asp-append-version="true"></script>
}
