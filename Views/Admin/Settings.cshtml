@{
    ViewData["Title"] = "Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Settings</div>
        <div class="page-subtitle">System configuration, company details and portal settings</div>
    </div>
    <button class="btn btn-primary" id="btnSaveSettings">💾 Save Settings</button>
</div>

<div class="two-col">
    <div class="card">
        <div class="section-label">Company Details</div>
        <div class="form-group"><label>Company Name</label><input type="text" value="Gayatri Restaurant Pte Ltd"></div>
        <div class="form-group"><label>UEN</label><input type="text" value="201234567A"></div>
        <div class="form-group"><label>Address</label><input type="text" value="2 Tessensohn Road, Singapore 217664"></div>
        <div class="form-group"><label>Email</label><input type="email" value="catering@gayatri.com.sg"></div>
        <div class="form-group"><label>Hotline</label><input type="tel" value="+65 6294 6294"></div>
        <div class="form-group"><label>WhatsApp</label><input type="tel" value="+65 9123 4567"></div>
    </div>
    <div class="card">
        <div class="section-label">Portal Settings</div>
        <div class="form-group"><label>Default Deposit %</label><input type="number" value="50" min="0" max="100"></div>
        <div class="form-group"><label>Quotation Validity (days)</label><input type="number" value="14" min="1"></div>
        <div class="form-group"><label>Min Order Pax</label><input type="number" value="20" min="1"></div>
        <div class="form-group"><label>GST Rate (%)</label><input type="number" value="9" min="0"></div>
        <div class="form-group"><label>Service Charge (%)</label><input type="number" value="10" min="0"></div>
        <div class="form-group">
            <label>Portal Mode</label>
            <select>
                <option>Live</option>
                <option>Maintenance</option>
            </select>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/settings.js" asp-append-version="true"></script>
}
