@{
    ViewData["Title"] = "Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true">
    }

    <div class="page-header">
        <div>
            <div class="page-title">Settings</div>
            <div class="page-subtitle">System configuration, company details and portal settings</div>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" id="btnSaveSettings" onclick="savesettings()">Save Settings</button>
        </div>
    </div>

    <div class="two-col">
        <div class="card">
            <div class="panel-header">
                <div class="panel-title">Company Details</div>
            </div>
            <div class="form-group">
                <label>Company Name</label>
                <input id="Compname" type="text" class="form-control">
            </div>
            <div class="form-group">
                <label>UEN</label>
                <input id="uen" type="text" class="form-control">
            </div>
            <div class="form-group">
                <label>Address</label>
                <input id="address" type="text" class="form-control">
            </div>
            <div class="form-group">
                <label>Email</label>
                <input id="email" type="email" class="form-control">
            </div>
            <div class="form-group">
                <label>Hotline</label>
                <input id="hotline" type="tel" class="form-control">
            </div>
            <div class="form-group">
                <label>WhatsApp</label>
                <input id="whatsapp" type="tel" class="form-control">
            </div>
        </div>
        <div class="card">
            <div class="panel-header">
                <div class="panel-title">Portal Settings</div>
            </div>
            <div class="form-group">
                <label>Default Deposit %</label>
                <input id="defaultdep" type="number" value="50" min="0" max="100" class="form-control">
            </div>
            <div class="form-group">
                <label>Quotation Validity (days)</label>
                <input id="Quotaval" type="number" value="14" min="1" class="form-control">
            </div>
            <div class="form-group">
                <label>Min Order Pax</label>
                <input id="Minorder" type="number" value="20" min="1" class="form-control">
            </div>
            <div class="form-group">
                <label>GST Rate (%)</label>
                <input id="gstrate" type="number" value="9" min="0" class="form-control">
            </div>
            <div class="form-group">
                <label>Service Charge (%)</label>
                <input id="Servicechar" type="number" value="10" min="0" class="form-control">
            </div>
            <div class="form-group">
                <label>Portal Mode</label>
                <select>
                    <option>Live</option>
                    <option>Maintenance</option>
                </select>
            </div>
        </div>
        <input type="hidden" id="settingId" />
    </div>

    @section Scripts {
        <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
        <script src="~/js/admin/settings.js" asp-append-version="true"></script>
    }
