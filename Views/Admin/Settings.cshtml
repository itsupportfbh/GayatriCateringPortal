@{
    ViewData["Title"] = "Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/settings.css" asp-append-version="true">
    }

    <div class="page-header">
        <div>
            <div class="page-title">Settings</div>
            <div class="page-subtitle">System configuration, company details and portal settings</div>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-primary" id="btnSaveSettings" onclick="savesettings()">Save Settings</button>
        </div>
    </div>

    <div class="settings-loader-shell" id="settingsPanel">
        <div class="pageloaderpanel hidden">
            <div class="spinner"></div>
            <div class="loader-text">Loading settings...</div>
        </div>
        <div id="settingsContentWrap">
            <div class="settings-page">
                <div class="settings-layout">
            <div class="settings-left">
                <div class="card settings-card">
                    <div class="panel-header">
                        <div class="panel-title">Company & Contact</div>
                    </div>
                    <div class="settings-fields cols-2">
                        <div class="form-group">
                            <label>Company Name</label>
                            <input type="text" id="Compname" maxlength="100" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>UEN</label>
                            <input type="text" id="uen" maxlength="50" class="form-control">
                        </div>
                        <div class="form-group span-2">
                            <label>Address</label>
                            <input type="text" id="address" maxlength="200" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="email" maxlength="200" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Hotline</label>
                            <input type="tel" id="hotline" maxlength="40" class="form-control">
                        </div>
                        <div class="form-group span-2">
                            <label>WhatsApp</label>
                            <input type="tel" id="whatsapp" maxlength="40" class="form-control">
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-right">
                <div class="card settings-card">
                    <div class="panel-header">
                        <div class="panel-title">Bank Details</div>
                    </div>
                    <div class="settings-fields cols-2">
                        <div class="form-group span-2">
                            <label>Account Holder Name</label>
                            <input type="text" id="accountHolderName" maxlength="50" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>IFSC Code</label>
                            <input type="text" id="ifscCode" maxlength="30" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Account No</label>
                            <input type="text" id="accNo" maxlength="50" class="form-control">
                        </div>
                        <div class="form-group span-2">
                            <label>UPI Id</label>
                            <input type="text" id="upiId" maxlength="100" class="form-control">
                        </div>
                    </div>
                </div>

                <div class="card settings-card">
                    <div class="panel-header">
                        <div class="panel-title">Portal Settings</div>
                    </div>
                    <div class="settings-fields cols-2 compact">
                        <div class="form-group">
                            <label>Default Deposit %</label>
                            <input type="number" id="defaultdep" value="0" min="0" max="100" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Quotation Validity (days)</label>
                            <input type="number" id="Quotaval" value="0" min="1" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Min Order Pax</label>
                            <input type="number" id="Minorder" value="0" min="1" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>GST Rate (%)</label>
                            <input type="number" id="gstrate" value="0" min="0" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Service Charge (%)</label>
                            <input type="number" id="Servicechar" value="0" min="0" class="form-control">
                        </div>
                        <div class="form-group">
                            <label>Portal Mode</label>
                            <select id="portalmode" class="form-control">
                                <option>Live</option>
                                <option>Maintenance</option>
                            </select>
                        </div>
                    </div>
                    <input type="hidden" id="settingId" />
                </div>
            </div>
        </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
        <script src="~/js/admin/settings.js" asp-append-version="true"></script>
    }
