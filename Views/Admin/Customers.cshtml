@{
    ViewData["Title"] = "Customers";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/customers.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Customers</div>
        <div class="page-subtitle">Customer database and order history</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="custSearch" placeholder="Search customers...">
        </div>
        <button class="btn btn-orange btn-add" id="btnAddCustomer" onclick="openCustomerModal()">+ Add Customer</button>
    </div>
</div>




<!-- List Customer Modal  -->
<div class="table-wrap">
    <table class="tbl" id="customerList" data-page-size="10">
        <thead>
            <tr><th class="sortable">S.NO</th><th class="sortable">Code</th><th class="sortable">Name</th><th class="sortable">Mobile</th><th class="sortable">Email</th><th class="sortable">Remarks</th><th class="sortable">Status</th><th class="no-sort">Actions</th></tr>
        </thead>
        <tbody>


        </tbody>
    </table>
</div>
<!-- Add Customer Modal ( per-view) -->
<div class="modal-overlay hidden" id="customersModal">
    <div class="modal-box customer-modal-box">

        <!-- Header -->
        <div class="modal-header">
            <span class="modal-title">Create / Edit Customer</span>

            <button class="modal-close"
                    type="button"
                    onclick="closeCustomerModal()">
                ✕
            </button>
        </div>

        <!-- Hidden Id -->
        <input type="hidden" id="customerId" />

        <!-- Customer Form -->
        <div class="customer-form-grid">

            <!-- Code -->
            <div class="form-group">
                <label>Code</label>
                <input type="text"
                       id="customerCode"
                       class="form-control"
                       placeholder="Customer code" />
            </div>

            <!-- Name -->
            <div class="form-group">
                <label>Name</label>
                <input type="text"
                       id="customerName"
                       class="form-control"
                       placeholder="Customer name" />
            </div>

            <!-- Mobile -->
            <div class="form-group">
                <label>Mobile No</label>
                <input type="text"
                       id="customerMobileNo"
                       class="form-control"
                       placeholder="Mobile number" />
            </div>

            <!-- Email -->
            <div class="form-group">
                <label>Email</label>
                <input type="email"
                       id="customerEmailId"
                       class="form-control"
                       placeholder="Email address" />
            </div>

            <!-- Company -->
            <div class="form-group">
                <label>Company</label>
                <input type="text"
                       id="customerCompanyName"
                       class="form-control"
                       placeholder="Company name" />
            </div>

            <!-- Date Of Birth -->
            <div class="form-group">
                <label>Date of Birth</label>
                <input type="date"
                       id="customerDateOfBirth"
                       class="form-control" />
            </div>

            <!-- Gender -->
            <div class="form-group">
                <label>Gender</label>

                <select id="customerGender"
                        class="form-control">

                    <option value="">Select Gender</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                    <option value="3">Other</option>

                </select>
            </div>

            <!-- Pincode -->
            <div class="form-group">
                <label>Pincode</label>
                <input type="text"
                       id="customerPincode"
                       class="form-control"
                       placeholder="Pincode" />
            </div>

            <!-- Country -->
            <div class="form-group">
                <label>Country</label>
                <input type="number"
                       id="customerCountryId"
                       class="form-control"
                       placeholder="Country Id" />
            </div>

            <!-- State -->
            <div class="form-group">
                <label>State</label>
                <input type="number"
                       id="customerStateId"
                       class="form-control"
                       placeholder="State Id" />
            </div>

            <!-- City -->
            <div class="form-group">
                <label>City</label>
                <input type="number"
                       id="customerCityId"
                       class="form-control"
                       placeholder="City Id" />
            </div>

            <!-- Remarks -->
            <div class="form-group">
                <label>Remarks</label>
                <input type="text"
                       id="customerRemarks"
                       class="form-control"
                       placeholder="Remarks" />
            </div>

            <!-- Address Line 1 -->
            <div class="form-group full-width">
                <label>Address Line 1</label>
                <input type="text"
                       id="customerAddressLine1"
                       class="form-control"
                       placeholder="Address line 1" />
            </div>

            <!-- Address Line 2 -->
            <div class="form-group full-width">
                <label>Address Line 2</label>
                <input type="text"
                       id="customerAddressLine2"
                       class="form-control"
                       placeholder="Address line 2" />
            </div>

        </div>

        <!-- Footer Actions -->
        <div class="actions customer-modal-actions">
            <button type="button"
                    class="btn btn-light"
                    onclick="clearCustomerForm()">
                Clear
            </button>

            <button type="button"
                    class="btn btn-primary"
                    onclick="saveCustomer()">
                Save
            </button>
        </div>

    </div>
</div>















<!-- Add Customer Modal (static, per-view) -->


@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/customers.js" asp-append-version="true"></script>
}
