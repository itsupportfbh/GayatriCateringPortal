@{
    ViewData["Title"] = "Customers";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/customers.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Customers</div>
        <div class="page-subtitle">Customer database and order history</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="custSearch" class="tbl-search" data-table="customerList" placeholder="Search customers...">
        </div>
        <button class="btn btn-orange btn-add" id="btnAddCustomer" data-permission="create" onclick="openCustomerModal()">+ Add Customer</button>
    </div>
</div>

<div class="pageloaderfull hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading customers...</div>
</div>

<div id="customersListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Customers</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage customers and their contact records.</div>
    <div class="pageloaderpanel hidden">
        <div class="spinner"></div>
        <div class="loader-text">Loading customers...</div>
    </div>
    <div class="table-wrap">
        <table class="tbl" id="customerList" data-page-size="10">
            <thead>
                <tr><th class="sortable">#</th><th class="sortable">Code</th><th class="sortable">Name</th><th class="sortable">Mobile</th><th class="sortable">Email</th><th class="sortable">Remarks</th><th class="sortable">Status</th><th class="no-sort">Actions</th></tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay hidden" id="customersModal">
    <div class="modal-box customers-modal-box">
        <div class="modal-header">
            <span class="modal-title" id="customers-title">Create Customer</span>
            <button class="modal-close" type="button" onclick="closeCustomerModal()">✕</button>
        </div>

        <input type="hidden" id="customerId" />

        <div class="form-row col3">
            <div class="form-group">
                <label>Code</label>
                <input type="text" id="customerCode" class="form-control" placeholder="e.g. CUST001" />
            </div>
            <div class="form-group">
                <label>Name<span class="field-required">*</span></label>
                <input type="text" id="customerName" class="form-control" placeholder="Enter customer name" />
            </div>
            <div class="form-group">
                <label>Email<span class="field-required">*</span></label>
                <input type="email" id="customerEmailId" class="form-control" placeholder="name@example.com" />
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Mobile No<span class="field-required">*</span></label>
                <input type="text" id="customerMobileNo" class="form-control" placeholder="Enter mobile number" />
            </div>
            <div class="form-group">
                <label>Date of Birth</label>
                <input type="date" id="customerDateOfBirth" class="form-control" />
            </div>
            <div class="form-group">
                <label>Age</label>
                <input type="number" id="customerAge" class="form-control" placeholder="Auto-calculated" disabled />
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Gender<span class="field-required">*</span></label>
                <select id="customerGender" class="form-control">
                    <option value="">Select Gender</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                    <option value="3">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Address Line 1<span class="field-required">*</span></label>
                <input type="text" id="customerAddressLine1" class="form-control" placeholder="Enter address line 1" />
            </div>
            <div class="form-group">
                <label>Address Line 2</label>
                <input type="text" id="customerAddressLine2" class="form-control" placeholder="Enter address line 2 (optional)" />
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Country<span class="field-required">*</span></label>
                <select id="customerCountryId" class="form-control">
                </select>
            </div>
            <div class="form-group">
                <label>State<span class="field-required">*</span></label>
                <select id="customerStateId" class="form-control">
                </select>
            </div>
            <div class="form-group">
                <label>City<span class="field-required">*</span></label>
                <select id="customerCityId" class="form-control">
                </select>
            </div>
        </div>

        <div class="form-row col3">
            <div class="form-group">
                <label>Postal Code</label>
                <input type="text" id="customerPincode" class="form-control" placeholder="Enter postal code" />
            </div>
            <div class="form-group">
                <label>Remarks</label>
                <input type="text" id="customerRemarks" class="form-control" placeholder="Enter remarks (optional)" />
            </div>
        </div>

        <div class="actions">
            <button type="button" class="btn btn-light" onclick="clearCustomerForm()">Clear</button>
            <button type="button" class="btn btn-primary" onclick="saveCustomer()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/customers.js" asp-append-version="true"></script>
}
