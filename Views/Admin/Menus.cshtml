@{
    ViewData["Title"] = "Menu Master";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/menus.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Menu Master</div>
        <div class="page-subtitle">Manage all menu items, categories, prices and availability</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="menuSearch" placeholder="Search menu items...">
            <select id="catFilter">
                <option value="">All Categories</option>
                <option>Rice & Breads</option>
                <option>Vegetarian</option>
                <option>Non-Vegetarian</option>
                <option>Snacks</option>
                <option>Desserts</option>
                <option>Drinks</option>
            </select>
        </div>
        <button class="btn btn-orange" id="btnAddMenu">+ Add Item</button>
    </div>
</div>

<div class="card">
    <div class="table-wrap" id="menuTable">
        <p class="muted">Loading...</p>
    </div>
</div>

<!-- Add Menu Modal -->
<div class="modal-overlay hidden" id="addMenuModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title">Add Menu Item</span>
            <button class="modal-close">✕</button>
        </div>
        <div class="form-group"><label>Item Name *</label><input type="text" id="newItemName" placeholder="e.g. Paneer Tikka"></div>
        <div class="form-row col2">
            <div class="form-group">
                <label>Category</label>
                <select id="newItemCat">
                    <option>Rice & Breads</option><option>Vegetarian</option><option>Non-Vegetarian</option>
                    <option>Snacks</option><option>Desserts</option><option>Drinks</option>
                </select>
            </div>
            <div class="form-group"><label>Price (S$/pax)</label><input type="number" id="newItemPrice" min="0" step="0.50" value="3.00"></div>
        </div>
        <div class="form-group">
            <label>Type</label>
            <select id="newItemType"><option>Veg</option><option>Non-Veg</option></select>
        </div>
        @Html.AntiForgeryToken()
        <div class="actions"><button class="btn btn-primary" id="btnSaveMenu">Save Item</button></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/menus.js" asp-append-version="true"></script>
}
