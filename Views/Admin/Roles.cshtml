@{
    ViewData["Title"] = "Roles & Permissions";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/roles.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Roles &amp; Permissions</div>
        <div class="page-subtitle">Backend roles and function matrix for portal access</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="rolesSearch" data-table="rolesMatrix" placeholder="Search roles...">
        </div>
        <button class="btn btn-orange">+ Add Role</button>
    </div>
</div>

