            </tbody>
        </table>
    </div>
</div>


<!-- Roles modal (moved from JS) -->
<div class="modal hidden" id="rolesModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Manage Roles</h3>
            <button class="modal-close">×</button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <input type="hidden" id="roleId" />
                <label>Code</label>
                <input type="text" id="roleCode" placeholder="Role code (eg. ADMIN)" />
                <label>Name</label>
                <input type="text" id="roleName" placeholder="Role name" />
                <label>Remarks</label>
                <input type="text" id="roleRemarks" placeholder="Remarks" />
                <label><input type="checkbox" id="roleIsActive" checked /> Active</label>
                <div class="modal-actions">
                    <button id="btnSaveRole" class="btn btn-orange">Save</button>
                    <button id="btnClearRole" class="btn">Clear</button>
                </div>
            </div>
            <hr />
            <div class="table-wrap">
                <table class="tbl" id="rolesList">
                    <thead>
                        <tr><th>Id</th><th>Code</th><th>Name</th><th>Remarks</th><th>Active</th><th>Actions</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/roles.js" asp-append-version="true"></script>
}