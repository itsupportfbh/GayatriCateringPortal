@{
    ViewData["Title"] = "Roles & Permissions";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/roles.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Roles &amp; Permissions</div>
        <div class="page-subtitle">Backend roles and function matrix for portal access</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="rolesSearch" placeholder="Search roles...">
        </div>
        <button class="btn btn-orange" id="btnOpenRoleModal">+ Add Role</button>
    </div>
</div>

<div id="rolesListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Roles</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage roles. Use Role Permission to assign rights by role.</div>
    <div class="table-wrap">
        <table class="tbl" id="rolesList">
            <thead>
                <tr><th>Id</th><th>Code</th><th>Name</th><th>Remarks</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay hidden" id="rolesModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title">Create / Edit Role</span>
            <button class="modal-close">✕</button>
        </div>
        <div class="form-group">
            <label>Code</label>
            <input type="text" id="roleCode" class="form-control" placeholder="Role code (eg. ADMIN)" />
        </div>
        <div class="form-group">
            <label>Name</label>
            <input type="text" id="roleName" class="form-control" placeholder="Role name" />
        </div>
        <div class="form-group">
            <label>Remarks</label>
            <input type="text" id="roleRemarks" class="form-control" placeholder="Remarks" />
        </div>
        <input type="hidden" id="roleId" />
        <div class="actions">
            <button type="button" class="btn btn-light" id="btnClearRole">Clear</button>
            <button type="button" class="btn btn-primary" id="btnSaveRole">Save</button>
        </div>
    </div>
</div>

<div id="rolesPermissionPanel" class="card hidden">
    <div class="panel-header">
        <div class="panel-title">Role Permission</div>
        <div class="panel-actions">
            <button id="btnBackToRoles" class="btn">Back to Roles</button>
        </div>
    </div>
    <div class="muted" style="margin-bottom:16px">Viewing permissions for role: <strong id="selectedRoleName">None</strong></div>
    <div class="table-wrap">
        <table class="tbl" id="rolesMatrix">
            <thead>
                <tr>
                    <th>Function</th>
                    <th>Super Admin</th>
                    <th>Admin</th>
                    <th>Sales</th>
                    <th>Accounts</th>
                    <th>Kitchen Admin</th>
                    <th>Kitchen Staff</th>
                    <th>Logistics</th>
                    <th>Customer Service</th>
                    <th>Viewer</th>
