@{
    ViewData["Title"] = @ViewData["Title"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/roles.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Roles &amp; Permissions</div>
        <div class="page-subtitle">Backend roles and function matrix for portal access</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="rolesSearch" class="tbl-search" data-table="rolesList" placeholder="Search roles...">
        </div>
        <button class="btn btn-orange" onclick="openRolesModal()">+ Add Role</button>
    </div>
</div>

<div class="pageloaderfull hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading roles...</div>
</div>

<div id="rolesListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Roles</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage roles. Use Role Permission to assign rights by role.</div>
    <div class="pageloaderpanel hidden">
        <div class="spinner"></div>
        <div class="loader-text">Loading roles...</div>
    </div>
    <div class="table-wrap">
        <table class="tbl" id="rolesList" data-page-size="10">
            <thead>
                <tr><th class="sortable">#</th><th class="sortable">Code</th><th class="sortable">Name</th><th class="sortable">Remarks</th><th class="sortable">Status</th><th class="no-sort">Actions</th></tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay hidden" id="rolesModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="model-title">Create / Edit Role</span>
            <button class="modal-close" type="button" onclick="closeRolesModal()">✕</button>
        </div>
        <div class="form-group">
            <label>Code <span class="field-required">*</span></label>
            <input type="text" id="roleCode" class="form-control" placeholder="Role code (eg. ADMIN)" />
            <div class="field-error hidden" id="roleCodeError"></div>
        </div>
        <div class="form-group">
            <label>Name <span class="field-required">*</span></label>
            <input type="text" id="roleName" class="form-control" placeholder="Enter role name" />
            <div class="field-error hidden" id="roleNameError"></div>
        </div>
        <div class="form-group">
            <label>Remarks</label>
            <input type="text" id="roleRemarks" class="form-control" placeholder="Enter remarks (optional)" />
        </div>
        <input type="hidden" id="roleId" />
        <div class="actions">
            <button type="button" class="btn btn-light" onclick="clearRoleForm(true)">Clear</button>
            <button type="button" id="saveRoleBtn" class="btn btn-primary" onclick="saveRole()">Save</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/roles.js" asp-append-version="true"></script>
}