                <tr>
                    <th>Function</th>
                    <th>Super Admin</th>
                    <th>Admin</th>
                    <th>Sales</th>
                    <th>Accounts</th>
                    <th>Kitchen Admin</th>
                    <th>Kitchen Staff</th>
                    <th>Logistics</th>
                    <th>Customer Service</th>
                    <th>Viewer</th>
                </tr>
            </thead>
