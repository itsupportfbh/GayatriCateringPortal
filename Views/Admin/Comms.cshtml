@{
    ViewData["Title"] = "Communications";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/comms.css" asp-append-version="true">
    }

    <div class="page-header">
        <div>
            <div class="page-title">Communications</div>
            <div class="page-subtitle">Communication log — WhatsApp, email and SMS history</div>
        </div>
        <div class="page-header-actions">
            <button class="btn btn-orange btn-add" id="btnAddComms" onclick="openCommsModal()">+ Log Communication</button>
        </div>
    </div>

    <div id="commsListPanel" class="card">
        <div class="panel-header">
            <div class="panel-title">Communication Log</div>
        </div>
        <div class="muted" style="margin-bottom:16px">Track outbound communication across WhatsApp, email and SMS.</div>
        <div class="pageloaderpanel hidden">
            <div class="spinner"></div>
            <div class="loader-text">Loading comms...</div>
        </div>
        <div class="table-wrap">
            <table class="tbl" id="commsList" data-page-size="10">
                <thead>
                    <tr>
                        <th class="sortable">#</th>
                        <th class="sortable">Channel</th>
                        <th class="sortable">To Address</th>
                        <th class="sortable">Message</th>
                        <th class="sortable">Status</th>
                        <th class="sortable">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- rows rendered by ~/js/admin/comms.js -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Per-view Comms modal -->
    <div class="modal-overlay hidden" id="commsModal">
        <div class="modal-box">
            <div class="modal-header">
                <span class="modal-title">Log Communication</span>
                <button class="modal-close" type="button" onclick="closeCommsModal()">✕</button>
            </div>
            <div class="form-group">
                <label>Channel</label>
                <select id="cmChannel" class="form-control">
                    <option value="">Select channel</option>
                    <option>WhatsApp</option>
                    <option>Email</option>
                    <option>SMS</option>
                </select>
            </div>
            <div class="form-group">
                <label>To Address</label>
                <input id="cmAddress" maxlength="100" class="form-control" placeholder="Enter To Address">
            </div>
            <div class="form-group">
                <label>Message</label>
                <textarea id="cmMsgField" class="form-control" placeholder="Enter message details"></textarea>
            </div>
            <div class="actions">
                <button class="btn btn-light" id="btnClearComms" onclick="clearCommsForm()">Clear</button>
                <button class="btn btn-primary" id="btnSaveComms" onclick="saveComms()">Save</button>
            </div>
        </div>
        <input type="hidden" id="CommsId" />
    </div>

    @section Scripts {
        <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
        <script src="~/js/admin/comms.js" asp-append-version="true"></script>
    }
