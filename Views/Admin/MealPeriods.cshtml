@{
    ViewData["Title"] = "Meal Periods";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/mealperiods.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Meal Periods</div>
        <div class="page-subtitle">Configure meal period time slots and availability</div>
    </div>
    <div class="page-header-actions">
        <div class="app-header-filter">
            <input type="text" id="mealPeriodsSearch" class="tbl-search" data-table="mealPeriodList" placeholder="Search meal periods...">
        </div>
        <button class="btn btn-orange btn-add" id="btnAddPeriod" onclick="openMealPeriodModal()">+ Add MealPeriod</button>
    </div>
</div>

<div class="pageloaderfull hidden">
    <div class="spinner"></div>
    <div class="loader-text">Loading meal periods...</div>
</div>

<div id="mealPeriodsListPanel" class="card">
    <div class="panel-header">
        <div class="panel-title">Manage Meal Periods</div>
    </div>
    <div class="muted" style="margin-bottom:16px">Create, edit and manage service time slots for catering operations.</div>
    <div class="pageloaderpanel hidden">
        <div class="spinner"></div>
        <div class="loader-text">Loading meal periods...</div>
    </div>
    <div class="table-wrap">

        <table class="tbl" id="mealPeriodList" data-page-size="10">

            <thead>
                <tr>
                    <th class="sortable">#</th>
                    <th class="sortable">Code</th>
                    <th class="sortable">Meal Period Name</th>
                    <th class="sortable">Start Time</th>
                    <th class="sortable">End Time</th>
                    <th class="sortable">Display Order</th>
                    <th class="sortable">Active</th>
                    <th class="no-sort">Actions</th>
                </tr>
            </thead>

            <tbody>
                <!-- rows rendered by ~/js/admin/mealperiods.js -->
            </tbody>

        </table>

    </div>
</div>


<!-- Add Meal Period Modal -->
<div class="modal-overlay hidden" id="mealPeriodsModal">

    <div class="modal-box">

        <!-- Header -->
        <div class="modal-header">

            <span class="modal-title" id="mealPeriods-title">
                Create Meal Period
            </span>

            <button class="modal-close"
                    type="button"
                    onclick="closeMealPeriodModal()">
                ✕
            </button>

        </div>


        <!-- Hidden Id -->
        <input type="hidden"
               id="mealPeriodId" />


        <div class="form-row col2">
            <div class="form-group">
                <label>Code</label>
                <input type="text" id="mealPeriodCode" class="form-control" placeholder="e.g. MP001" />
            </div>
            <div class="form-group">
                <label>Meal Period Name<span class="field-required">*</span></label>
                <input type="text" id="mealPeriodName" class="form-control" placeholder="Enter meal period name" />
            </div>
        </div>

        <div class="form-row col2">
            <div class="form-group">
                <label>Start Time<span class="field-required">*</span></label>
                <input type="time" id="mealPeriodStartTime" class="form-control" />
            </div>
            <div class="form-group">
                <label>End Time<span class="field-required">*</span></label>
                <input type="time" id="mealPeriodEndTime" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <div class="form-group">
                <label>Display Order<span class="field-required">*</span></label>
                <input type="number" id="mealPeriodDisplayOrder" class="form-control" min="1" placeholder="Enter display order" />
            </div>
        </div>

        <div class="actions">
            <button type="button" class="btn btn-light" onclick="clearMealPeriodForm()">Clear</button>
            <button type="button" class="btn btn-primary" onclick="saveMealPeriod()">Save</button>
        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/admin/table-utils.js" asp-append-version="true"></script>
    <script src="~/js/admin/mealperiods.js" asp-append-version="true"></script>
}
