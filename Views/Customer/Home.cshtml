@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer/home.css" asp-append-version="true">
}

<div class="home-pdf">
    <div class="home-topbar" id="about">
        <div class="home-logo">
            <img src="~/images/logo.jpg" alt="Gayatri Restaurant">
            <div class="home-logo-copy">
                <span>GAYATRI</span>
                <small>RESTAURANT</small>
            </div>
        </div>
        <nav class="home-nav">
            <a class="home-link" href="#about">About</a>
            <a class="home-link" href="/Customer/Menu">Menu</a>
            <a class="home-link" href="/Customer/Packages">Catering</a>
            <a class="home-link order-link" href="/Customer/Order">Order Catering</a>
        </nav>
    </div>

    <div class="pdf-hero">
        <div>
            <div class="hero-logo-panel">
                <img src="~/images/logo.jpg" alt="Gayatri Logo">
                <span>Gayatri Restaurant</span>
            </div>
            <h1>Authentic Indian Catering with Function Hall Setup.</h1>
            <p>Choose Indian buffet, breakfast, hi-tea, banana leaf, wedding feast or corporate lunch box. Package dish choices are included in package value; extra items have qty and prices separately.</p>
            <div class="home-cta">
                <a class="btn btn-orange" href="/Customer/Order">Start New Order</a>
                <a class="btn btn-light" href="/Customer/Menu">View Menus</a>
                <a class="btn btn-primary" href="/Customer/Venue">Function Hall</a>
                <a class="btn btn-primary" href="https://wa.me/6562946294" target="_blank">WhatsApp 62946294</a>
            </div>
        </div>
    </div>

    <div class="pdf-section peach" id="menu">
        <h2>Our Signature Canapes</h2>
        <div class="pdf-grid">
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/sigPani.jpg" alt="Pani Puri Shots"><b>Pani Puri Shots</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/sigPapdi.jpg" alt="Papdi Chaat"><b>Papdi Chaat</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/sigChanna.jpg" alt="Channa Masala"><b>Channa Masala</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/sigPaneer.jpg" alt="Zafrani Paneer Skewers"><b>Zafrani Paneer Skewers</b></a>
        </div>
    </div>

    <div class="pdf-section" id="catering">
        <div class="pdf-kicker">Who We Serve</div>
        <h2 style="text-align:center">We're More Than Just A Restaurant</h2>
        <div class="pdf-grid">
            <a class="pdf-item" href="/Customer/Order"><img src="~/images/serveWedding.jpg" alt="Weddings &amp; Celebrations"><b>Weddings &amp; Celebrations</b></a>
            <a class="pdf-item" href="/Customer/Order"><img src="~/images/serveCorporate.jpg" alt="Corporate Events"><b>Corporate Events</b></a>
            <a class="pdf-item" href="/Customer/Order"><img src="~/images/serveMedia.jpg" alt="Large Media Events"><b>Large Media Events</b></a>
        </div>
        <p class="pdf-copy"><b><i>We provide full-service</i></b> catering for weddings, private celebrations, corporate events, and community functions, capable of serving up to 5,000 guests per day during weekends and public holidays.</p>
    </div>

    <div class="pdf-section" id="top-picks">
        <h2>Our Guests'<br>Top Picks</h2>
        <div class="pdf-grid">
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/pickChicken.jpg" alt="Chicken Masala"><b>Chicken Masala</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/pickPaneer.jpg" alt="Paneer Butter Masala"><b>Paneer Butter Masala</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/pickChai.jpg" alt="Masala Chai"><b>Masala Chai</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/pickTahu.jpg" alt="Tahu Sambal"><b>Tahu Sambal</b></a>
            <a class="pdf-item" href="/Customer/Menu"><img src="~/images/pickGulab.jpg" alt="Gulab Jamun"><b>Gulab Jamun</b></a>
        </div>
        <div class="hall-row" style="margin-top:30px">
            <div>
                <h2>Celebrations Hall<br>Singapore Khalsa Association</h2>
                <p class="pdf-copy" style="font-size:14px;margin-top:8px">Function hall setup for events, buffet service and table arrangements.</p>
                <a class="btn btn-primary" href="/Customer/Venue" style="margin-top:14px;display:inline-flex">View Function Hall</a>
            </div>
            <div class="hall-gallery">
                <img src="~/images/hall1.jpg" alt="Celebrations Hall view">
                <img src="~/images/hall2.jpg" alt="Celebrations Hall table setting">
                <img src="~/images/hall3.jpg" alt="Celebrations Hall buffet line">
            </div>
        </div>
    </div>

    <div class="pdf-section peach" id="packages">
        <h2>Packages / Set Up Options</h2>
        <div class="pdf-grid">
            <a class="pdf-item" href="/Customer/Venue"><img src="~/images/setupLed.jpg" alt="LED Wall Panel"><b>LED Wall Panel</b></a>
            <a class="pdf-item" href="/Customer/Venue"><img src="~/images/setupSound.jpg" alt="Sound System"><b>Sound System</b></a>
            <a class="pdf-item" href="/Customer/Packages"><img src="~/images/setupBuffet.jpg" alt="Buffet Setting"><b>Buffet Setting</b></a>
            <a class="pdf-item" href="/Customer/Venue"><img src="~/images/setupTable.jpg" alt="Table Setting"><b>Table Setting</b></a>
        </div>
        <h2 style="margin-top:34px">What Our Clients Say</h2>
        <div class="testimonial-grid">
            <div class="testimonial">
                <div class="name">Priyamani</div>
                <p>Wonderful and excellent service. On-time schedule, fantastic setup and display, and excellent food from all the guests.</p>
                <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
            <div class="testimonial">
                <div class="name">Ravimohan</div>
                <p>All the guests said the food was very nice and service was fast and polite. Thank you very much once again.</p>
                <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
            <div class="testimonial">
                <div class="name">John Raj</div>
                <p>Feedback from our guests is that food was nice and the team was helpful. Thank you.</p>
                <div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            </div>
        </div>
    </div>

    <div class="pdf-section" id="contact">
        <div class="contact-top">
            <div class="home-logo">
                <img src="~/images/logo.jpg" alt="Gayatri Restaurant">GAYATRI<br>
                <small style="font-size:12px;letter-spacing:8px">RESTAURANT</small>
            </div>
            <p class="contact-tagline">At Gayatri, we don't just serve food, we share stories, aromas, and memories steeped in the soul of our rich Indian culture.</p>
        </div>
        <div class="contact-cards">
            <div class="contact-card">
                <div class="contact-card-icon">&#128336;</div>
                <div class="contact-card-title">Restaurant Hours</div>
                <div class="contact-card-line">Mon - Sat: 11:00am - 10:30pm</div>
                <div class="contact-card-line">Sunday: 10:30am - 10:30pm</div>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">&#128205;</div>
                <div class="contact-card-title">Address</div>
                <div class="contact-card-line">122 Race Course Road</div>
                <div class="contact-card-line">#01-01, Singapore 218583</div>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">&#128222;</div>
                <div class="contact-card-title">Catering Hotline</div>
                <div class="contact-card-line">+65 6294 6294</div>
                <div class="contact-card-line">+65 6292 4544 (Office)</div>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">&#128172;</div>
                <div class="contact-card-title">WhatsApp Us</div>
                <div class="contact-card-line">+65 9123 4567</div>
                <div class="contact-card-line"><a href="https://wa.me/6591234567" target="_blank" class="btn btn-orange btn-sm" style="margin-top:8px">Chat Now</a></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/customer/home.js" asp-append-version="true"></script>
}
