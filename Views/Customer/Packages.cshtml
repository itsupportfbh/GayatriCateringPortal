@{
    ViewData["Title"] = "Packages";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customer/packages.css" asp-append-version="true">
}

<div class="page-header">
    <div>
        <div class="page-title">Catering Packages</div>
        <div class="page-subtitle">Pre-configured packages with dish choices and pricing per pax</div>
    </div>
    <a href="/Customer/Order" class="btn btn-orange">Order Now</a>
</div>

<!-- PACKAGES -->
<div class="packages-layout">
    <section>
        <div class="preset-grid" id="packageCards">
            <div class="card package-loading-card">
                <div class="pageloaderpanel">
                    <div class="spinner" aria-hidden="true"></div>
                    <div class="loader-text">Loading packages...</div>
                </div>
            </div>
        </div>
    </section>

    <aside class="package-sidebar" id="packageSidebar" aria-live="polite">
        <div class="package-detail-heading">
            <div class="package-detail-kicker">Package menu</div>
            <h2 id="packageDetailTitle">Select a package</h2>
            <div class="package-detail-subtitle">Click View on any package card to see menu categories.</div>
            <div class="package-detail-meta" id="packageDetailMeta">
                <span class="meta-pill">Ready</span>
            </div>
        </div>
        <div class="package-detail-content" id="packageDetailContent">
            <div class="package-detail-status">Package details will appear here.</div>
        </div>
    </aside>
</div>

